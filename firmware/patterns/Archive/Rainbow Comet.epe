{
  "name": "Rainbow Comet",
  "id": "YMaaLW2gyQ7HZRaYy",
  "sources": {
    "main": "//@kylarleds\n\npixelsval = array(pixelCount)\npixelshue = array(pixelCount)\npixelssat = array(pixelCount)\n\nspeed = .06\nfade = 0.9\n\nexport function sliderSpeed(v){\n  speed = (1.1-v)/3\n}\n\nexport function sliderFade(v){\n  fade = 1-(v/20)\n}\n\nlastidx = 0\nexport function beforeRender(delta) {\n  \n  hue = time(0.14)\n  pos = triangle(time(speed))\n  idx = floor(pos*pixelCount) // The current pixel in front\n\n\n  \n  i = min(lastidx, idx)\n  end = max(lastidx, idx)\n  \n  if(end-i < pixelCount-3){\n    while(i <= end){            // This is to account for missed pixels in case we are moving really fast\n      pixelsval[(i)] = 1\n      pixelshue[(i)] = hue // This is the starting color. 0=red, 0.33=green, 0.66=blue\n      pixelssat[(i)] = 0.8 // The leading pixel is given some saturation\n      \n      i++;\n    }\n  }\n  \n  lastidx = idx\n  \n}\n\nexport function render(index) {\n  v = pixelsval[index]\n  v = v*v\n  pixelshue[index] -= 0.01      // Change this to make the rainbow longer or shorter\n  pixelssat[index] *= 1.1       // Change this to mess with the white at the front\n  pixelssat[index] = pixelssat[index] > 1 ? 1 : pixelssat[index]  // Set the max value to 1\n  pixelsval[index] = max(0, pixelsval[index]*fade) \n  hsv(pixelshue[index], pixelssat[index], v)\n}"
  },
  "preview": ""
}