    "main": "var red = 1\nvar blue = 0\nvar green = 0\n\nexport function rgbPickerPrimaryColor(r, g, b)\n{\n  \n  green = g\n  blue = b\n  red = r\n  \n}\n\nexport function render(index) {\n   // rgb(1, 1, 1) //white\n   rgb(red, green, blue) //red\n  //rgb(r, g, b) //teal\n  // rgb(1, .15, 0) //orangeish\n  // rgb(1, 1, 0) //yellowgreen\n  // rgb(1, 1, .3) //warm white\n}"
