{
  "name": "policeLights",
  "id": "KePy7cXKAsvmxCbNo",
  "sources": {
    "main": "// Alternating red/blue flashing strip lights.\n// Lloyd Taylor ltaylor@netelder.com 3 August 2019\n// version 1.0\n\nfirstcolor = 1\ntimer=0\nblinkrate = 200 // rate of flashing in mSec\\\nblocksize = 10 // number of sequential leds in one color\n\nexport function beforeRender(delta) {\n  timer += delta\n  if (timer > blinkrate){\n    timer = 0\n    if (firstcolor == 1) {\n      firstcolor = 0.7\n      secondcolor = 1.0\n    }\n    else {\n      firstcolor = 1.0\n      secondcolor = 0.7\n    }\n  }  \n  \n}\n\nexport function render(index) {\n  if (index/blocksize & 1) color=firstcolor\n  else color=secondcolor\n  hsv(color, 1, 1)\n}"
  },
  "preview": ""
}