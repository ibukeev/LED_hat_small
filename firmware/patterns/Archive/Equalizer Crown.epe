{
  "name": "Equalizer Crown",
  "id": "mQEDx3KuFAXj8TfY9",
  "sources": {
    "main": "// Pattern: Equalizer Crown (Minimal)\n// Description: Frequency bands mapped to columns around the hat with bar-height response.\n// Version: 0.1\n\n// Minimal controls\nexport var outputLevel = 0.85\nexport var inputSensitivity = 0.8\nexport var colorHue = 0.62 // cool blue default\n\n// Sensor Expansion Board audio vars\nexport var frequencyData = array(32)\nexport var energyAverage = -1\n\nvar COLS = 12\nvar ROWS = 7\n\nvar energy = 0\nvar colValue = array(16)\nvar colPeak = array(16)\nvar colRaw = array(16)\nvar bandLo = array(16)\nvar bandHi = array(16)\nvar bandsReady = 0\n\nfunction clamp01(v) {\n  if (v < 0) return 0\n  if (v > 1) return 1\n  return v\n}\n\nfunction lerp(a, b, t) {\n  return a + (b - a) * t\n}\n\nfunction normalizeHeight(h) {\n  // Native expected range is 0..1 (bottom->top).\n  // If mapper supplies centered coordinates (-1..1), remap to 0..1.\n  var n = h\n  if (h < 0 || h > 1) n = h * 0.5 + 0.5\n  n = clamp01(n)\n  // Hardware-verified for this project: invert to map physical bottom to 0.\n  return 1 - n\n}\n\nfunction initBands() {\n  if (bandsReady) return\n\n  // Fixed band groups across 12 columns (low -> high).\n  bandLo[0] = 1;  bandHi[0] = 1\n  bandLo[1] = 2;  bandHi[1] = 2\n  bandLo[2] = 3;  bandHi[2] = 3\n  bandLo[3] = 4;  bandHi[3] = 4\n  bandLo[4] = 5;  bandHi[4] = 6\n  bandLo[5] = 7;  bandHi[5] = 8\n  bandLo[6] = 9;  bandHi[6] = 10\n  bandLo[7] = 11; bandHi[7] = 13\n  bandLo[8] = 14; bandHi[8] = 16\n  bandLo[9] = 17; bandHi[9] = 20\n  bandLo[10] = 21; bandHi[10] = 25\n  bandLo[11] = 26; bandHi[11] = 31\n\n  bandsReady = 1\n}\n\nfunction updateAudioColumns() {\n  var gate = 0\n  if (energyAverage >= 0) {\n    // Absolute gate tuned from your measured range.\n    var energyFloor = 0.0007 + (1 - inputSensitivity) * 0.0022\n    var energyCeil = 0.008 + (1 - inputSensitivity) * 0.016\n    gate = clamp01((energyAverage - energyFloor) / max(0.0001, energyCeil - energyFloor))\n    gate = pow(gate, 0.85)\n  }\n  energy = gate\n\n  // Peak decay: lower sensitivity -> faster decay (less sticky bars).\n  var peakDecay = 0.985 + inputSensitivity * 0.012\n\n  var spectrumSum = 0.00001\n\n  for (var c = 0; c < COLS; c++) {\n    var lo = bandLo[c]\n    var hi = bandHi[c]\n    var raw = 0\n    var count = hi - lo + 1\n    for (var b = lo; b <= hi; b++) raw += frequencyData[b]\n    raw /= max(1, count)\n\n    colRaw[c] = raw\n    spectrumSum += raw\n  }\n\n  for (c = 0; c < COLS; c++) {\n    var raw = colRaw[c]\n\n    // Local normalization keeps each band usable.\n    colPeak[c] = max(colPeak[c] * peakDecay, raw)\n    var norm = raw / max(0.00001, colPeak[c])\n\n    // Spectral-share term preserves differences between columns.\n    var share = (raw / spectrumSum) * COLS\n\n    var gain = 0.6 + inputSensitivity * 2.2\n    var localTerm = clamp01(norm * gain)\n    var shareTerm = clamp01(share * (0.55 + inputSensitivity * 0.65))\n\n    var target = clamp01(localTerm * 0.58 + shareTerm * 0.42) * energy\n\n    // Fast attack, moderate release.\n    colValue[c] = lerp(colValue[c], target, 0.38)\n  }\n}\n\nfunction renderCore(x, y, z) {\n  var col = floor(clamp01(x) * COLS)\n  if (col >= COLS) col = COLS - 1\n\n  var bar = colValue[col]\n  var yy = normalizeHeight(y)\n  var row = floor(yy * ROWS)\n  if (row >= ROWS) row = ROWS - 1\n\n  // Quantize to physical rows so low levels still light row 1 reliably.\n  var litRows = floor(bar * ROWS + 0.0001)\n  if (bar > 0.02 && litRows < 1) litRows = 1\n  if (litRows > ROWS) litRows = ROWS\n\n  var v = 0\n  if (row < litRows) {\n    // Bright near the top of currently lit rows.\n    var topPos = (row + 1) / max(1, litRows)\n    var topBoost = 0.65 + 0.35 * topPos\n    v = bar * topBoost\n  }\n\n  // Keep physical bottom band always on as a stable baseline.\n  // Uses a height threshold instead of exact row index to tolerate map offsets.\n  if (yy <= (1 / ROWS + 0.02)) {\n    var base = 0.12 + 0.10 * energy\n    if (v < base) v = base\n  }\n\n  v = clamp01(v * outputLevel)\n  hsv(colorHue, 0.95, v)\n}\n\nexport function beforeRender(delta) {\n  initBands()\n  updateAudioColumns()\n}\n\nexport function render(index) {\n  // 1D fallback assumes hat wiring is column-major with 7 rows.\n  var cols = max(1, floor(pixelCount / ROWS))\n  var col = floor(index / ROWS)\n  var row = index % ROWS\n  var u = col / max(1, cols - 1)\n  var h = row / max(1, ROWS - 1)\n  renderCore(u, h, 0)\n}\n\nexport function render2D(index, x, y) {\n  // 2D maps are assumed x=around, y=height.\n  renderCore(x, y, 0)\n}\n\nexport function render3D(index, x, y, z) {\n  // Cylinder map: x/y define angle (column), z defines height.\n  var angle = atan2(y, x) / (PI * 2) + 0.5\n  renderCore(angle, z, 0)\n}\n\n// Minimal UI\nexport function sliderOutputLevel(v) { outputLevel = 0.1 + v * 0.9 }\nexport function sliderInputSensitivity(v) { inputSensitivity = v }\nexport function sliderColor(v) { colorHue = v }"
  },
  "preview": ""
}