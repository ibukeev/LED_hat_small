{
  "name": "Riot Pulse",
  "id": "evamZ7NtEhZXjbjoA",
  "sources": {
    "main": "// Pattern: Riot Pulse (Minimal)\n// Description: Aggressive center-out and edge-in pulses locked to rhythm.\n// Version: 0.2\n\n// Minimal controls\nexport var outputLevel = 0.85\nexport var inputSensitivity = 0.8\nexport var colorHue = 0.02 // warm red/orange default\n\n// Sensor Expansion Board audio vars\nexport var frequencyData = array(32)\nexport var energyAverage = -1\n\nvar t = 0\nvar low = 0\nvar mid = 0\nvar high = 0\nvar energy = 0\n\nvar lowPeak = 0.01\nvar midPeak = 0.01\nvar highPeak = 0.01\n\n// Pulse states\nvar outPos = -1\nvar inPos = -1\nvar outAmp = 0\nvar inAmp = 0\n\nfunction clamp01(v) {\n  if (v < 0) return 0\n  if (v > 1) return 1\n  return v\n}\n\nfunction updateAudio() {\n  var fl = 0\n  var fm = 0\n  var fh = 0\n\n  if (energyAverage >= 0) {\n    var lowRaw = frequencyData[1] + frequencyData[2] + frequencyData[3] + frequencyData[4]\n    var midRaw = frequencyData[7] + frequencyData[8] + frequencyData[9] + frequencyData[10] + frequencyData[11]\n    var highRaw = frequencyData[20] + frequencyData[21] + frequencyData[22] + frequencyData[23] + frequencyData[24] + frequencyData[25] + frequencyData[26] + frequencyData[27] + frequencyData[28] + frequencyData[29]\n\n    lowPeak = max(lowPeak * 0.996, lowRaw)\n    midPeak = max(midPeak * 0.996, midRaw)\n    highPeak = max(highPeak * 0.996, highRaw)\n\n    fl = clamp01((lowRaw / max(0.00001, lowPeak)) * (0.9 + 2.4 * inputSensitivity))\n    fm = clamp01((midRaw / max(0.00001, midPeak)) * (0.8 + 2.0 * inputSensitivity))\n    fh = clamp01((highRaw / max(0.00001, highPeak)) * (0.6 + 1.2 * inputSensitivity))\n\n    var floor = 0.0007 + (1 - inputSensitivity) * 0.0022\n    var ceil = 0.008 + (1 - inputSensitivity) * 0.016\n    energy = clamp01((energyAverage - floor) / max(0.0001, ceil - floor))\n    energy = pow(energy, 0.85)\n  } else {\n    energy = 0\n  }\n\n  var prevLow = low\n  var prevMid = mid\n\n  low = low * 0.68 + fl * 0.32\n  mid = mid * 0.70 + fm * 0.30\n  high = high * 0.72 + fh * 0.28\n\n  // Kick onset -> center-out pulse.\n  var lowOnset = low - prevLow\n  var lowThresh = 0.030 + (1 - inputSensitivity) * 0.045\n  if (lowOnset > lowThresh && energy > 0.08) {\n    outPos = 0\n    outAmp = 0.65 + 0.35 * low\n  } else {\n    outAmp *= 0.90\n  }\n\n  // Mid onset -> edge-in pulse.\n  var midOnset = mid - prevMid\n  var midThresh = 0.028 + (1 - inputSensitivity) * 0.040\n  if (midOnset > midThresh && energy > 0.06) {\n    inPos = 1\n    inAmp = 0.55 + 0.35 * mid\n  } else {\n    inAmp *= 0.89\n  }\n}\n\nfunction renderCore(x, y, z) {\n  // Distance from center (0=center, 1=edge)\n  var d = abs(x - 0.5) * 2\n  var v = 0\n\n  if (outPos >= 0) {\n    var wOut = 0.08 + 0.18 * (1 - inputSensitivity)\n    var pOut = exp(-pow((d - outPos) / wOut, 2))\n    v += pOut * outAmp\n  }\n\n  if (inPos >= 0) {\n    var wIn = 0.08 + 0.16 * (1 - inputSensitivity)\n    var pIn = exp(-pow((d - inPos) / wIn, 2))\n    v += pIn * inAmp\n  }\n\n  // High band adds subtle grain on top.\n  var grain = sin((x * 67 + y * 19 + z * 13 + t * 18) * PI * 2) * 0.5 + 0.5\n  if (grain > 0.90) v += high * 0.18\n\n  // Keep it dark between hits, but not invisible on small setups.\n  v = v * (0.24 + 1.45 * energy)\n  v = clamp01(v * outputLevel)\n\n  hsv(colorHue, 0.95, v)\n}\n\nexport function beforeRender(delta) {\n  t += delta / 1000\n  updateAudio()\n\n  // Advance pulse positions once per frame (not per pixel).\n  var speed = (0.05 + 0.09 * energy) * (delta / 16.67)\n  if (outPos >= 0) {\n    outPos += speed\n    if (outPos > 1.2) outPos = -1\n  }\n  if (inPos >= 0) {\n    inPos -= speed * 1.05\n    if (inPos < -0.2) inPos = -1\n  }\n}\n\nexport function render(index) {\n  var x = (index + 0.5) / pixelCount\n  renderCore(x, 0, 0)\n}\n\nexport function render2D(index, x, y) {\n  renderCore(x, y, 0)\n}\n\nexport function render3D(index, x, y, z) {\n  var x1d = (index + 0.5) / pixelCount\n  renderCore(x1d, y, z)\n}\n\n// Minimal UI\nexport function sliderOutputLevel(v) { outputLevel = 0.1 + v * 0.9 }\nexport function sliderInputSensitivity(v) { inputSensitivity = v }\nexport function sliderColor(v) { colorHue = v }"
  },
  "preview": ""
}