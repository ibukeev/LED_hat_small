{
  "name": "Mapping Row Test",
  "id": "RLbiDyiDC2xYBkY3a",
  "sources": {
    "main": "// Pattern: Mapping Row Test\n// Description: Static bottom-up row fill for mapping verification.\n// Version: 0.1\n\nvar ROWS = 7\n\n// Controls\nexport var rowsLit = 0          // 0..7\nexport var colorHue = 0.55\nexport var outputLevel = 0.8\nexport var flipVertical = 0     // 0=normal, 1=invert\n\nfunction clamp01(v) {\n  if (v < 0) return 0\n  if (v > 1) return 1\n  return v\n}\n\nfunction normHeight(h) {\n  var n = h\n  // Accept either 0..1 or -1..1 style coordinates.\n  if (h < 0 || h > 1) n = h * 0.5 + 0.5\n  n = clamp01(n)\n  if (flipVertical > 0.5) n = 1 - n\n  return n\n}\n\nfunction renderCore(h) {\n  var litFrac = rowsLit / ROWS\n  var v = h <= litFrac ? outputLevel : 0\n  hsv(colorHue, 1, v)\n}\n\nexport function render(index) {\n  // 1D fallback assumes column-major wiring with 7 rows.\n  var row = index % ROWS\n  var h = row / max(1, ROWS - 1)\n  h = normHeight(h)\n  renderCore(h)\n}\n\nexport function render2D(index, x, y) {\n  var h = normHeight(y)\n  renderCore(h)\n}\n\nexport function render3D(index, x, y, z) {\n  var h = normHeight(z)\n  renderCore(h)\n}\n\n// UI sliders\nexport function sliderRowsLit(v) {\n  rowsLit = floor(v * (ROWS + 0.999))\n  if (rowsLit > ROWS) rowsLit = ROWS\n}\nexport function sliderColor(v) { colorHue = v }\nexport function sliderOutputLevel(v) { outputLevel = 0.05 + v * 0.95 }\nexport function sliderFlipVertical(v) { flipVertical = v >= 0.5 ? 1 : 0 }"
  },
  "preview": ""
}