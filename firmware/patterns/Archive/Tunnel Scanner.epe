{
  "name": "Tunnel Scanner",
  "id": "D5AKmsZzB8DPTy3T7",
  "sources": {
    "main": "// Pattern: Tunnel Scanner (Techno Bunker)\n// Description: A hard-edged scanning beam with kick boosts, trail echoes, and spark grit.\n// Version: 0.3\n\n// Main controls\nexport var intensity = 0.8\nexport var darknessFloor = 0.0\nexport var sweepSpeed = 0.65\nexport var beamWidth = 0.14\nexport var trailDecay = 0.42\nexport var jitter = 0.08\nexport var kickBoost = 2.1\nexport var sparkAmount = 0.34\nexport var colorHue = 0.33 // 0..1 hue control (default acid green)\nexport var colorSat = 1.0\n\n// Audio/reactivity controls\nexport var audioGain = 1.8\nexport var energyFloor = 0.0012\nexport var energyCeil = 0.012\nexport var manualLow = 0.0\nexport var manualMid = 0.0\nexport var manualHigh = 0.0\n\n// Values populated by Pixelblaze Sensor Expansion Board when connected.\nexport var frequencyData = array(32)\nexport var energyAverage = -1\nexport var maxFrequency = 0\nexport var maxFrequencyMagnitude = 0\n\nvar elapsed = 0\nvar PI2 = PI * 2\nvar low = 0\nvar mid = 0\nvar high = 0\nvar kick = 0\nvar lowPeak = 0.01\nvar midPeak = 0.01\nvar highPeak = 0.01\nvar energy = 0\n\nfunction clamp01(v) {\n  if (v < 0) return 0\n  if (v > 1) return 1\n  return v\n}\n\nfunction lerp(a, b, t) {\n  return a + (b - a) * t\n}\n\nfunction pingpong(t) {\n  var p = t % 2\n  if (p > 1) return 2 - p\n  return p\n}\n\nfunction updateReactiveBands() {\n  var fl = 0\n  var fm = 0\n  var fh = 0\n\n  // True audio reactivity from Sensor Expansion Board FFT + energy values.\n  if (energyAverage >= 0) {\n    var lowRaw = frequencyData[1] + frequencyData[2] + frequencyData[3] + frequencyData[4]\n    var midRaw = frequencyData[6] + frequencyData[7] + frequencyData[8] + frequencyData[9] + frequencyData[10] + frequencyData[11] + frequencyData[12]\n    var highRaw = frequencyData[18] + frequencyData[19] + frequencyData[20] + frequencyData[21] + frequencyData[22] + frequencyData[23] + frequencyData[24] + frequencyData[25] + frequencyData[26] + frequencyData[27] + frequencyData[28] + frequencyData[29] + frequencyData[30] + frequencyData[31]\n\n    // Auto-gain normalization so music level changes don't kill dynamics.\n    lowPeak = max(lowPeak * 0.992, lowRaw)\n    midPeak = max(midPeak * 0.992, midRaw)\n    highPeak = max(highPeak * 0.992, highRaw)\n\n    // Absolute gate based on measured sensor range.\n    energy = clamp01((energyAverage - energyFloor) / max(0.0001, energyCeil - energyFloor))\n    energy = pow(energy, 0.8)\n\n    fl = clamp01((lowRaw / max(0.00001, lowPeak)) * audioGain * (0.35 + 1.45 * energy))\n    fm = clamp01((midRaw / max(0.00001, midPeak)) * audioGain * (0.20 + 1.10 * energy))\n    fh = clamp01((highRaw / max(0.00001, highPeak)) * audioGain * (0.15 + 1.00 * energy))\n  }\n\n  // Smooth to reduce chatter at high frame rates.\n  var lowTarget = clamp01(max(fl, manualLow))\n  var midTarget = clamp01(max(fm, manualMid))\n  var highTarget = clamp01(max(fh, manualHigh))\n\n  // Bass onset detector: only rising edges create punch flashes.\n  var onset = lowTarget - low\n  if (onset > 0.045) {\n    kick = max(kick, clamp01(onset * (1.6 + kickBoost * 0.8)))\n  }\n  kick *= 0.84\n\n  low = lerp(low, lowTarget, 0.35)\n  mid = lerp(mid, midTarget, 0.26)\n  high = lerp(high, highTarget, 0.32)\n}\n\nfunction renderCore(x, y, z) {\n  // Scanner position with kick-driven speedup.\n  var rate = sweepSpeed * (0.55 + low * kickBoost * 1.85 + kick * 2.2)\n  var pos = pingpong(elapsed * rate)\n\n  // Rough machine jitter.\n  var jitterPhase = elapsed * (6 + 12 * high) + y * 1.7 + z * 0.9\n  var posJitter = (sin(jitterPhase * PI2) * 0.5 + 0.5 - 0.5) * jitter * 0.35\n  pos = clamp01(pos + posJitter)\n\n  var dist = abs(x - pos)\n  var bw = 0.02 + beamWidth * 0.35\n  var beam = exp(-pow(dist / bw, 2.0))\n\n  // Trail behind the beam depending on sweep direction.\n  var p2 = (elapsed * rate) % 2\n  var dir = 1\n  if (p2 > 1) dir = -1\n\n  var behind = 0\n  if (dir > 0) {\n    behind = pos - x\n  } else {\n    behind = x - pos\n  }\n\n  var trail = 0\n  if (behind > 0) {\n    trail = exp(-behind / (0.03 + trailDecay * 0.35)) * (0.25 + 0.75 * mid)\n  }\n\n  // High-band spark grit.\n  var grain = sin((x * 73 + y * 29 + z * 11 + elapsed * 22) * PI2) * 0.5 + 0.5\n  var spark = 0\n  if (grain > (0.92 - 0.25 * high)) {\n    spark = high * sparkAmount\n  }\n\n  var v = darknessFloor\n  v += beam * (0.2 + 1.7 * low)\n  v += trail * (0.15 + 0.95 * mid)\n  v += spark * (0.12 + 0.75 * high)\n  // Short full-frame punch on kick onsets.\n  v += kick * (0.35 + 0.75 * energy)\n  v *= 0.12 + 1.25 * energy\n  v = clamp01(v * intensity)\n\n  // Saturation rises with energy so quiet parts are less color-dense.\n  var mixAmt = clamp01(0.2 + low * 0.6 + high * 0.2)\n  hsv(colorHue, colorSat * mixAmt, v)\n}\n\nexport function beforeRender(delta) {\n  elapsed += delta / 1000\n  updateReactiveBands()\n}\n\n// 1D fallback\nexport function render(index) {\n  var x = (index + 0.5) / pixelCount\n  renderCore(x, 0, 0)\n}\n\nexport function render2D(index, x, y) {\n  renderCore(x, y, 0)\n}\n\nexport function render3D(index, x, y, z) {\n  var x1d = (index + 0.5) / pixelCount\n  renderCore(x1d, y, z)\n}\n\n// Pixelblaze UI controls: minimal set for fast testing\nexport function sliderOutputLevel(v) {\n  intensity = 0.15 + v * 0.85\n}\n\nexport function sliderInputSensitivity(v) {\n  audioGain = 0.8 + v * 2.8\n  energyFloor = 0.0004 + (1 - v) * 0.0026\n  energyCeil = 0.006 + (1 - v) * 0.018\n  kickBoost = 0.8 + v * 2.8\n  sparkAmount = 0.08 + v * 0.52\n}\n\nexport function sliderColor(v) {\n  colorHue = v\n}"
  },
  "preview": ""
}