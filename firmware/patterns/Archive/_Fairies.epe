{
  "name": "_Fairies",
  "id": "iwMghZwpJEeiQ2ndk",
  "sources": {
    "main": "/*\n  FireFlies\n  \n  This is a fork of the sparks pattern where each spark is:\n    - Slowed down \n    - Given a longer lifetime \n    - Allowed to loop from one end to the other\n  \n  This is a highly upvoted pattern generously contributed to the community\n  pattern library by an unknown person. Please reach out if you'd like an\n  attribution link here!\n*/\n\nexport var sparkHue = .85       // Set the hue for each spark\nexport function hsvPickerPrimaryColor(h, s, v){\n  sparkHue = h\n}\n\n\nnumFairies = floor(1 + (pixelCount / 2))\nnumSparks =  floor(1 + (pixelCount / 16))\nnumTotal = numFairies + numSparks // Scale number of sparks based on # LEDs\n\nsparks = array(numTotal)\nsparkX = array(numTotal)\nsparklife = array(numTotal)\nsparkColor = array(numTotal)\n\nfor(i=0;i<numTotal;i++) {\n  if(i < numFairies) sparkColor[i] = 0\n  else\n    sparkColor[i] = 1\n\n}\n\n\n\n\npixels = array(pixelCount)\npixels_sat = array(pixelCount)\n\n\nbase_sparklife = 4000 //in ms.\nexport function sliderSpeed(v){\n  base_sparklife = _map(v,0,1,1500, 8000)\n}\n\nfunction seed() {\n  for (i = 0; i < numSparks; i++) {\n      sparkX[i] = random(pixelCount)\n      sparks[i] = random(1)\n      sparklife[i] = random(base_sparklife)\n  }\n}\n\nfunction _map(x, in_min, in_max, out_min, out_max) {\n  return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;\n}\n\nexport function beforeRender(delta) {\n  for (i = 0; i < numTotal; i++) {\n    decay_this_round = _map(delta, 0, sparklife[i], 0, 1)\n    // Recycle dead sparks\n    if(sparks[i] <= 0) {\n      sparkX[i] = random(pixelCount)\n      sparks[i] = 1\n      \n      if(sparkColor[i] < 1) {\n        sparklife[i] = _map(random(1), 0, 1, base_sparklife*.8, base_sparklife*1.2)\n      } else {\n        sparklife[i] = _map(random(1), 0, 1, base_sparklife*.2, base_sparklife*.4)\n      }\n    } else {\n      sparks[i] -= decay_this_round\n    }\n    \n    ptr = sparkX[i]\n    if(sparkColor[i] < 1) {\n      pixels[ptr] = sparks[i]\n      pixels_sat[ptr] = 1\n    } else {\n      pixels[ptr] = sparks[i]\n      pixels_sat[ptr] = 0\n    }\n  }\n}\n\nexport function render(index) {\n  v = pixels[index]\n  sat = pixels_sat[index]\n  hsv(sparkHue, sat, v*v)\n}"
  },
  "preview": ""
}