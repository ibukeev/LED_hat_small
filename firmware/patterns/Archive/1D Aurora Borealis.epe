{
  "name": "1D Aurora Borealis",
  "id": "MQjwtW3qw3YZ3Qujf",
  "sources": {
    "main": "/////////////////////////////////////////////////////\r\n//  AURORA BOREALIS SIMULATION\r\n//  Ported to PBscript from https://github.com/Mazn1191/Arduino-Borealis\r\n//\r\n//  Looks its best when diffused up a vertical surface (eg. with the LEDs placed near a wall, facing up)\r\n\r\n\r\n/////////////////////////////////////////////////////\r\n//  Palette of colors used for waves.\r\nvar colorPalettes = [   // 5 colors, expressed as RGB components\r\n  [  17, 177,  13 ],    //Greenish\r\n  [ 148, 242,   5 ],    //Greenish\r\n  [  25, 173, 121 ],    //Turquoise\r\n  [ 250,  77, 127 ],    //Pink\r\n  [ 171, 101, 221 ]     //Purple\r\n];\r\n\r\n//  paletteWeights give some colors more weight so they are more likely to be chosen for a wave.\r\nvar paletteWeights = [      // 3 presets, each with a different weighting for the 5 elements of the colorPalettes.\r\n  [ 20, 20, 20, 20, 20 ],   //Weighting equal (every color is equally likely)\r\n  [ 11, 11, 12, 33, 33 ],   //Weighting reddish (red colors are more likely)\r\n  [  6,  6,  6,  2,  1 ]    //Weighting greenish (green colors are more likely)\r\n];\r\n\r\n//  Function to get a random color from the palette.\r\nfunction getRandomColorIndex(whichPreset) {\r\n  sumOfWeights = paletteWeights[whichPreset].sum();\r\n  randomWeight = random(sumOfWeights);\r\n  for (i = 0; i < paletteWeights[whichPreset].length; i++) {\r\n    if (randomWeight < paletteWeights[whichPreset][i]) return i;\r\n    randomWeight -= paletteWeights[whichPreset][i];\r\n  }\r\n  return 0;\r\n}\r\n\r\n\r\n/////////////////////////////////////////////////////\r\n//  Utility functions.\r\nfunction scaleBetween(low, high, value) { return low + value * (high - low); }\r\nfunction randomBetween(low, high) { return scaleBetween(low, high, random(1)); }\r\n\r\n\r\n\r\n/////////////////////////////////////////////////////\r\n//  UI settings.\r\nexport var speedFactor = 3;     \r\nexport function sliderSpeed(v) { speedFactor = scaleBetween(1, 5, v); }\r\nexport var widthFactor = 0.3;     \r\nexport function sliderWidth(v) { widthFactor = scaleBetween(0.1, 0.5, v); }\r\nexport var whichPalette = 2;    \r\nexport function sliderPalette(v) { whichPalette = floor(scaleBetween(0, paletteWeights.length - 0.01, v)); }\r\nexport var numWaves = min(6, maxWaves);\r\nexport function sliderNumWaves(v) { numWaves = floor(scaleBetween(1, maxWaves, v)); }\r\n\r\n\r\n/////////////////////////////////////////////////////\r\n//  structure member offsets as array indices.\r\nvar _age = 0, _ttl = 1, _basecolor = 2, _basealpha = 3, _width = 4, _center = 5, _direction = 6, _speed = 7, STRUCTURE_SIZE = 8;\r\n\r\n//  Allocate storage for the Waves.\r\nvar maxWaves = 10;\r\nvar waves = array(maxWaves);  waves.forEach((v, i, a) => { a[i] = array(STRUCTURE_SIZE); } );\r\n//export var watchWave = waves[0];\r\n\r\n\r\n/////////////////////////////////////////////////////\r\n//  Renderers.\r\n//\r\nexport function beforeRender(delta) {\r\n  //  Can't pass function parameter directly into an array function lambda, for some reason.\r\n  passDelta = delta;  \r\n  \r\n  //  Update waves.\r\n  waves.forEach((v, i, a) => {\r\n    //  Only calculate the waves we're using.\r\n    if (i > numWaves) return;\r\n\r\n    //  Randomly change direction, since real aurorae do that.\r\n    if (random(1) < 0.03) v[_direction] *= -1;\r\n    \r\n    //Change position and age of wave. Determine if its still \"alive\".\r\n    v[_center] += v[_speed] * v[_direction];\r\n  \r\n    //  Has this wave outlived its usefulness?\r\n    var dead = false;\r\n    v[_age] += passDelta; if (v[_age] > v[_ttl]) dead = true;\r\n\r\n    //  Has this wave moved offscreen?\r\n    if (v[_center] + v[_width] < 0) dead = true;  //  Wave has moved off the left end.\r\n    if (v[_center] - v[_width] > 1) dead = true;  //  Wave has moved off the right end.\r\n\r\n    if (dead) {\r\n      //  If this wave has finished, spawn a new one.\r\n      v[_age] = 0;\r\n      v[_ttl] = randomBetween(15000, 30000); \r\n      v[_basecolor] = getRandomColorIndex(whichPalette);\r\n      v[_basealpha] = randomBetween(0.5, 1.0);\r\n      v[_width] = randomBetween(0.1, widthFactor);\r\n      v[_center] = random(1);\r\n      v[_direction] = random(1) >= 0.5 ? 1 : -1;\r\n      v[_speed] = speedFactor * randomBetween(0.1, 0.3) * 0.001;\r\n    }\r\n  } );\r\n}\r\n\r\nexport function render(index) {\r\n  //  Calculate our relative position.\r\n  position = index/pixelCount;\r\n  \r\n  //  For each active wave at this position, blend the colors.\r\n  mixedR = 0; mixedG = 0; mixedB = 0;\r\n  waves.forEach((v, i, a) => { \r\n    //  Only calculate the waves we're using.\r\n    if (i > numWaves) return;\r\n    \r\n    //  There's no color if this position isn't part of this wave.\r\n    var offset = abs(position - v[_center]);\r\n    if (offset > v[_width]) return;\r\n\r\n    //  The brightness is partly determined by the age of the wave; At half its maximum age it will be the brightest.\r\n    var ageFactor = triangle(sqrt(v[_age]/v[_ttl]));\r\n\r\n    //  The brightness is also determined by the distance of this LED from the center.\r\n    var offsetFactor = 1 - sqrt(offset / v[_width]);\r\n\r\n    //  Look up color from the palette, and then desaturate it according to the baseAlpha and other correction factors.\r\n    var thisR = (colorPalettes[v[_basecolor]][0]) / 255;\r\n    var thisG = (colorPalettes[v[_basecolor]][1]) / 255;\r\n    var thisB = (colorPalettes[v[_basecolor]][2]) / 255;\r\n    var thisA = offsetFactor * ageFactor * v[_basealpha];\r\n\r\n    //  Alpha-blend the new color into the mix.\r\n    mixedR = (thisR * thisA) + (mixedR * (1 - thisA));\r\n    mixedG = (thisG * thisA) + (mixedG * (1 - thisA));\r\n    mixedB = (thisB * thisA) + (mixedB * (1 - thisA));\r\n  } );\r\n  rgb(mixedR, mixedG, mixedB);\r\n}\r\n"
  },
  "preview": ""
}