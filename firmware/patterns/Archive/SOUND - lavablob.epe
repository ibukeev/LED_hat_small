{
  "name": "SOUND - lavablob",
  "id": "qJncNRaPgCW2x9eGD",
  "sources": {
    "main": "//works best on a matrix not had chance to try it out on a strip yet\n//messed around with boxfire to create this. so i cannot take any credit  I also say there are glaring errors \n//in here but its all part of the learning proccess :)\nexport var frequencyData\nexport var energyAverage\n\nspeed = 100*(frequencyData*1000)\n\nexport function beforeRender(delta) {\n  t1 = time(.1/speed)\n  t2 = time(.13/speed)\n  t3 = time(.085/speed)\n  scale = (.001 + triangle(time(.3)))*energyAverage*50\n}\n\nexport function render(index) {\n  render3D(index, index/pixelCount, 0, 0)\n}\n\nexport function render2D(index, x, y) {\n  render3D(index, x, y, 0)\n}\n\nexport function render3D(index, x, y, z) {\n  h = t1 + x*.2 + y*.2 + z*.2\n  s = h*h*h\n  v = (triangle(y*scale+wave(t1)) * wave(y*scale+wave(t2)) * wave(x*scale + wave(t3)))*10\n  s = v-1\n  v = frequencyData[16]*8*v*v\n  \n  hsv(h, s, v)\n}"
  },
  "preview": ""
}