{
  "name": "Gate Lightning Effect",
  "id": "FuRbkYXgaQxEHybKZ",
  "sources": {
    "main": "export var test_var = 1;\n\n\nvar red = 1;\nvar blue = 1;\nvar green = 1;\n\nexport function rgbPickerPrimaryColor(r, g, b) {\n  red = r;\n  blue = b;\n  green = g;\n}\n\nexport var seriesCooldown = 0.2; // Cooldown period between series of flashes (2000ms)\nexport function sliderCoolDown(v) {\n  seriesCooldown = v;\n  \n  \n}\n\n\nvar timeScale = 0.1;\nexport var t1 = 0;\nexport var flashSeries = array(6);\nexport var flashIndex = 0;\nexport var nextSeriesTime = 0.0;\n\nexport var seriesActive = false;\nvar brightness = 0;\nexport var flashSeries_duration = array(3);\nexport var flashSeries_interval = array(3); \nvar flashSeries_brightness = array(3);\nexport var durationEnd = 0;\n\n\n\n\nfunction generateFlashSeries() {\n  var numFlashes = random(3); // Randomize number of flashes in a series (3 to 6)\n  for (var i = 0; i < 3; i++) {\n    flashSeries_duration[i] = 0;\n    flashSeries_brightness[i] = 0;\n    flashSeries_interval[i] = 0;\n    \n  }\n  for (var i = 0; i < numFlashes; i++) {\n    var interval = random(timeScale*0.5); // Interval between flashes (50ms to 200ms)\n    var duration = random(timeScale*4); // Duration of each flash (20ms to 100ms)\n    var brightness = 0.5+random(0.5); // Brightness of each flash (50% to 100%)\n    flashSeries_duration[i] = duration;\n    flashSeries_brightness[i] = brightness;\n    flashSeries_interval[i] = interval;\n  }\n  flashIndex = 0;\n}\n\n\nexport function beforeRender(delta) {\n  t1 = time(timeScale*10)\n  \n  if (!seriesActive && t1 > nextSeriesTime) {\n  \n    generateFlashSeries();\n    seriesActive = true;\n  }\n  \n  \n  if (seriesActive)\n  {\n    if(flashSeries_duration[0] >0) {\n      if(t1 > nextSeriesTime)\n        {\n          \n          durationEnd = t1 + flashSeries_duration;\n          brightness = 1.0;\n          nextSeriesTime = t1 + flashSeries_interval[0];\n          if(nextSeriesTime>1.0) {nextSeriesTime=nextSeriesTime-1.0}\n          flashIndex++;\n          \n                if (t1 < durationEnd) {\n                      brightness = flashSeries_brightness[0];\n                } else {\n                brightness = 0;\n                }\n          \n          \n          \n          \n          \n          \n          \n        }\n        else \n        {\n          brightness = 0.0;\n          seriesActive = false;\n          \n        }\n      \n    }\n    else {\n      nextSeriesTime = t1 + seriesCooldown;\n      if(nextSeriesTime>1.0) {nextSeriesTime=nextSeriesTime-1.0}\n      \n      \n    }\n    \n    \n    \n  }\n}\n\n\n\nexport function render2D(index,x,y) {\n  \n  /*if(y < 0.5 & x < 0.5)\n  {rgb(1,0,0)}\n  else {rgb(0,1,0)}*/\n  if(nextSeriesTime>1.0) {nextSeriesTime = nextSeriesTime-1.0}\n    rgb(red * brightness, green * brightness, blue * brightness); // Example color (white) with lightning effect\n\n\n}"
  },
  "preview": ""
}