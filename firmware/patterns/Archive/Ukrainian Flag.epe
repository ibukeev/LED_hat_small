{
  "name": "Ukrainian Flag",
  "id": "W8zaKB37EpufM3oM7",
  "sources": {
    "main": "// Pattern: Ukrainian Flag (Reactive)\n// Description: Blue over yellow with optional blink/strobe and accelerometer reaction.\n// Version: 1.1\n\n// Flag colors (#005BBB and #FFD500)\nexport var blueR = 0.0\nexport var blueG = 0.357\nexport var blueB = 0.733\nexport var yellowR = 1.0\nexport var yellowG = 0.835\nexport var yellowB = 0.0\n\n// Flag layout\nexport var bandSplit = 0.5\nexport var bandSoftness = 0.0\nexport var tiltAmount = 0.25\nexport var centerBlue = 1\n\n// Time controls\nexport var speed = 1.0\nexport var blinkHz = 0.0\nexport var strobeStyle = 0   // 0=off, 1=smooth, 2=inLonger, 3=outLonger\nexport var strobeHz = 8.0\nexport var strobeDuty = 0.5\nexport var strobeInPow = 2.0\nexport var strobeOutPow = 2.0\n\n// Motion reaction\nexport var motionBoost = 0.6\nexport var motionScale = 2.0\n\n// Sensor Expansion Board values (Pixelblaze sets these when available)\nexport var light = -1\nexport var accelerometer\n\nvar PI2 = PI * 2\nvar elapsed = 0\n\n// Cached orientation/motion from beforeRender\nvar nx = 0\nvar ny = 0\nvar nz = 1\nvar motion = 0\n\nfunction clamp01(v) {\n  if (v < 0) return 0\n  if (v > 1) return 1\n  return v\n}\n\nfunction lerp(a, b, t) {\n  return a + (b - a) * t\n}\n\nfunction smoothstep(edge0, edge1, x) {\n  var t = clamp01((x - edge0) / (edge1 - edge0))\n  return t * t * (3 - 2 * t)\n}\n\nfunction hasSensor() {\n  return light != -1\n}\n\nfunction normalize3(x, y, z) {\n  var m = sqrt(x * x + y * y + z * z)\n  if (m <= 0) {\n    nx = 0\n    ny = 0\n    nz = 1\n    return\n  }\n  nx = x / m\n  ny = y / m\n  nz = z / m\n}\n\nfunction strobeEnvelope(phase, style) {\n  if (style == 1) return 0.5 - 0.5 * cos(phase * PI2)\n\n  var duty = strobeDuty\n  if (style == 2 && duty < 0.6) duty = 0.6\n  if (style == 3 && duty > 0.4) duty = 0.4\n\n  if (phase < duty) return pow(phase / duty, strobeInPow)\n  return pow((1 - phase) / (1 - duty), strobeOutPow)\n}\n\n// Pixelblaze UI controls\nexport function sliderBandSplit(v) { bandSplit = v }\nexport function sliderBandSoftness(v) { bandSoftness = v * 0.2 }\nexport function sliderTiltAmount(v) { tiltAmount = v }\nexport function sliderCenterBlue(v) { centerBlue = v >= 0.5 ? 1 : 0 }\n\nexport function sliderSpeed(v) { speed = v * 3 }\nexport function sliderBlinkHz(v) { blinkHz = v * 8 }\nexport function sliderStrobeStyle(v) { strobeStyle = floor(v * 3.999) }\nexport function sliderStrobeHz(v) { strobeHz = 1 + v * 19 }\nexport function sliderStrobeDuty(v) { strobeDuty = 0.1 + v * 0.8 }\nexport function sliderStrobeInPow(v) { strobeInPow = 0.5 + v * 4.5 }\nexport function sliderStrobeOutPow(v) { strobeOutPow = 0.5 + v * 4.5 }\n\nexport function sliderMotionBoost(v) { motionBoost = v * 2 }\nexport function sliderMotionScale(v) { motionScale = 0.5 + v * 4.5 }\n\nfunction renderCore(x, y, z) {\n  var height = x * nx + y * ny + z * nz\n  var split = bandSplit * nz\n\n  var t = 0\n  if (bandSoftness > 0) {\n    t = smoothstep(split - bandSoftness, split + bandSoftness, height)\n    if (centerBlue && height >= split) t = 1\n  } else if (height > split || (centerBlue && height == split)) {\n    t = 1\n  }\n\n  var r = lerp(yellowR, blueR, t)\n  var g = lerp(yellowG, blueG, t)\n  var b = lerp(yellowB, blueB, t)\n\n  var blink = 1\n  if (blinkHz > 0) {\n    if (((elapsed * blinkHz) % 1) >= 0.5) blink = 0\n  }\n\n  var strobe = 1\n  if (strobeStyle > 0 && strobeHz > 0) {\n    strobe = strobeEnvelope((elapsed * strobeHz) % 1, strobeStyle)\n  }\n\n  var envelope = clamp01(blink * strobe * (1 + motion * motionBoost))\n  rgb(r * envelope, g * envelope, b * envelope)\n}\n\nexport function beforeRender(delta) {\n  elapsed += (delta / 1000) * speed\n\n  motion = 0\n  var ax = 0\n  var ay = 0\n  var az = 1\n\n  if (hasSensor() && accelerometer) {\n    ax = accelerometer[0]\n    ay = accelerometer[1]\n    az = accelerometer[2]\n    var mag = sqrt(ax * ax + ay * ay + az * az)\n    motion = clamp01(abs(mag - 1) * motionScale)\n  }\n\n  // Build a mostly-up normal, tilted by gravity direction.\n  var tx = ax * tiltAmount\n  var ty = ay * tiltAmount\n  var tz = (1 - tiltAmount) + az * tiltAmount\n  normalize3(tx, ty, tz)\n}\n\n// 1D fallback for setups without map coordinates\nexport function render(index) {\n  var x = (index + 0.5) / pixelCount\n  renderCore(x, 0, 0)\n}\n\nexport function render2D(index, x, y) {\n  renderCore(x, y, 0)\n}\n\nexport function render3D(index, x, y, z) {\n  renderCore(x, y, z)\n}"
  },
  "preview": ""
}