// Pattern: Fixed BPM Flash Test
// Description: Detector-free flash test pattern for tuning timing, color, and release.
// Version: 0.1

var level = 0.9
var bpm = 128
var beatDivision = 1
var release = 0.965
var colorHue = 0.62
var colorSat = 0.95

var pulse = 0
var beatMs = 468.75
var elapsedMs = 0
var beatCount = 0

function updateBeatMs() {
  beatMs = 60000 / bpm
}

function triggerPulse() {
  beatCount += 1
  if ((beatCount % beatDivision) == 0) pulse = 1
}

export function beforeRender(delta) {
  elapsedMs += delta

  while (elapsedMs >= beatMs) {
    elapsedMs -= beatMs
    triggerPulse()
  }

  pulse *= release
}

export function render(index) {
  var v = pulse * level
  hsv(colorHue, colorSat, v)
}

export function render2D(index, x, y) {
  render(index)
}

export function render3D(index, x, y, z) {
  render(index)
}

export function sliderOutputLevel(v) { level = 0.1 + v * 0.9 }

export function inputNumberBPM(v) {
  bpm = floor(v + 0.5)
  if (bpm < 60) bpm = 60
  if (bpm > 220) bpm = 220
  updateBeatMs()
}

export function inputNumberBeatDivision(v) {
  if (v < 1.5) beatDivision = 1
  else if (v < 3) beatDivision = 2
  else beatDivision = 4
}

export function sliderRelease(v) { release = 0.9 + v * 0.095 }

export function hsvPickerColor(h, s, v) {
  colorHue = h
  colorSat = s
}

updateBeatMs()
