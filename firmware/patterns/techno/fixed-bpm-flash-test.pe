// Pattern: Fixed BPM Flash Test
// Description: Detector-free once-per-second flash test for tuning color and release.
// Version: 0.1

var level = 0.9
var release = 0.965
var colorHue = 0.62
var colorSat = 0.95

var pulse = 0
var elapsedMs = 0
var flashMs = 1000

export function beforeRender(delta) {
  elapsedMs += delta

  while (elapsedMs >= flashMs) {
    elapsedMs -= flashMs
    pulse = 1
  }

  pulse *= release
}

export function render(index) {
  var v = pulse * level
  hsv(colorHue, colorSat, v)
}

export function render2D(index, x, y) {
  render(index)
}

export function render3D(index, x, y, z) {
  render(index)
}

export function sliderOutputLevel(v) { level = 0.1 + v * 0.9 }

export function sliderRelease(v) { release = 0.9 + v * 0.095 }

export function hsvPickerColor(h, s, v) {
  colorHue = h
  colorSat = s
}
